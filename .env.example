# ── OPSAL — variáveis de ambiente ──────────────────────────────────────────
# Copiar para `.env.local` e preencher. NUNCA commitar `.env.local`.

# Supabase (projeto Postgres + Storage)
# URL do projeto, ex.: https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# service_role key — USAR APENAS NO SERVIDOR. Nunca expor no cliente.
# É lida só em código server-side (route handlers / server actions / server components).
SUPABASE_SERVICE_ROLE_KEY=

# Autenticação single-user
# Password única de entrada.
APP_PASSWORD=

# Segredo para assinar o cookie de sessão (HMAC). Gerar uma string aleatória longa.
# ex.: openssl rand -hex 32
SESSION_SECRET=

# Anthropic (extração WhatsApp → incidência)
ANTHROPIC_API_KEY=
